# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://qbmxwaxezifsnysxyyez.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_wi77_CtVF9qn56Cm3tB8Bg_Rk2p7RWt
SUPABASE_SERVICE_ROLE_KEY=

# App URL — used for CTA links in outbound emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — email delivery for notifications.
# Get an API key at https://resend.com. Without it, notifications still
# get persisted but no emails are sent.
RESEND_API_KEY=
RESEND_FROM=Forge <onboarding@resend.dev>

# Firebase Cloud Messaging — push notifications
# Web SDK config (public values, also pasted into public/firebase-messaging-sw.js):
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# VAPID key from FCM web push certificates section:
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Server-side (used by /api/push/dispatch — Wave 4c):
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Note: when pasting into Vercel, replace literal newlines with \n
FIREBASE_PRIVATE_KEY=

# Random secret for Vercel cron auth on /api/push/dispatch:
CRON_SECRET=

# Twilio — WhatsApp notifications (Wave 5)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox: whatsapp:+14155238886; production: whatsapp:+974XXXXXXXX
TWILIO_WHATSAPP_FROM=

# Twilio Content Template SIDs (from Twilio Console after approval).
# Leave unset to fall back to plain-text WhatsApp messages (sandbox only).
TWILIO_TEMPLATE_SCOPE_READY=
TWILIO_TEMPLATE_STAGE_APPROVED=
TWILIO_TEMPLATE_INVOICE_SENT=
TWILIO_TEMPLATE_PAYMENT_RECEIVED=
TWILIO_TEMPLATE_ORDER_COMPLETED=
