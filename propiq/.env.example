# Copy values into apps/api/.env and apps/web/.env.local respectively.
# This file documents every variable PropIQ uses.

# ── apps/api/.env ──────────────────────────────────────────────────────────

# Required
DATABASE_URL="postgresql://propiq:propiq_dev_password@localhost:5432/propiq"
JWT_SECRET="change-me-to-a-32-char-minimum-secret"
ANTHROPIC_API_KEY="sk-ant-YOUR_KEY_HERE"

# Auth
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="30d"

# Background jobs / cache
REDIS_URL="redis://localhost:6379"

# Storage — "local" stores under LOCAL_STORAGE_PATH; "azure" requires the
# (currently stub) Azure adapter in services/storage.ts to be implemented.
STORAGE_TYPE="local"
LOCAL_STORAGE_PATH="./uploads"

# SMTP — local dev uses MailHog (no auth, port 1025). For production set
# SMTP_HOST/SMTP_PORT/SMTP_SECURE plus add SMTP_USER/SMTP_PASS in services/email.ts.
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_SECURE="false"
EMAIL_FROM="noreply@propiq.local"

# WhatsApp Cloud API — optional. When unset, /api/whatsapp/send returns
# {delivered:false} and logs the activity as DRAFT (dev fallback).
WHATSAPP_API_URL="https://graph.facebook.com/v18.0"
WHATSAPP_PHONE_ID=""
WHATSAPP_TOKEN=""

# Server
PORT="3001"
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:3001"

# ── apps/web/.env.local ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_NAME="PropIQ"
NEXT_PUBLIC_DEFAULT_LOCALE="en"
