# Copy values into apps/api/.env and apps/web/.env.local respectively.
# This file documents every variable PropIQ uses.

# ── apps/api/.env ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://propiq:propiq_dev_password@localhost:5432/propiq"
JWT_SECRET="local-dev-secret-change-in-production-must-be-32-chars-minimum"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="30d"
ANTHROPIC_API_KEY="sk-ant-YOUR_KEY_HERE"
REDIS_URL="redis://localhost:6379"
STORAGE_TYPE="local"
LOCAL_STORAGE_PATH="./uploads"
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_SECURE="false"
EMAIL_FROM="noreply@propiq.local"
WHATSAPP_API_URL="https://graph.facebook.com/v18.0"
WHATSAPP_PHONE_ID=""
WHATSAPP_TOKEN=""
PORT="3001"
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:3001"

# ── apps/web/.env.local ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_NAME="PropIQ"
NEXT_PUBLIC_DEFAULT_LOCALE="en"
